{
  "name": "setup-bonsai",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build-entrypoint -- src/main.ts --outfile=dist/main.js && npm run build-entrypoint -- src/post.ts --outfile=dist/post.js",
    "build-entrypoint": "npx esbuild --bundle --platform=node --target=node20 --minify --sourcemap --sources-content=false"
  },
  "dependencies": {
    "@actions/cache": "^4.0.3",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1",
    "@actions/glob": "^0.5.0",
    "@actions/io": "^1.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "esbuild": "0.25.4",
    "typescript": "^5.8.3"
  }
}
